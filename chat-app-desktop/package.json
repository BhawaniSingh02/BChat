{
  "name": "baaat",
  "version": "1.0.4",
  "description": "Baaat — Professional Chat Desktop App",
  "main": "main.js",
  "author": "Baaat",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "release:win": "electron-builder --win && node scripts/upload.js win",
    "release:mac": "electron-builder --mac && node scripts/upload.js mac",
    "release:linux": "electron-builder --linux && node scripts/upload.js linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "auto-launch": "^5.0.6"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.baaat.app",
    "productName": "Baaat",
    "copyright": "Copyright © 2025 Baaat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "offline.html",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64"] },
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Network;InstantMessaging"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Baaat-Setup-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "BhawaniSingh02",
      "repo": "BChat"
    }
  }
}
